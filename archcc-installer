writeFile("usr/bin/systemctl.lua", [=[local args = { ... }
local unpackValues = table.unpack or unpack

local SYSTEM_DIRS = {
    "etc/systemd/system",
    "usr/lib/systemd/system",
}

local WANTS_DIR = "etc/systemd/system/multi-user.target.wants"
local RUN_DIR = "run/archcc/services"

local function mkdirp(path)
    local current = ""

    for part in path:gmatch("[^/]+") do
        current = fs.combine(current, part)

        if not fs.exists(current) then
            fs.makeDir(current)
        end
    end
end

local function writeFile(path, contents)
    mkdirp(fs.getDir(path))

    local handle = assert(fs.open(path, "w"))
    handle.write(contents)
    handle.close()
end

local function findUnit(name)
    for _, directory in ipairs(SYSTEM_DIRS) do
        local path = fs.combine(directory, name)

        if fs.exists(path) and not fs.isDir(path) then
            return path
        end
    end

    return nil
end

local function parseUnit(name)
    local path = findUnit(name)
    if not path then
        return nil
    end

    local unit = {
        path = path,
        values = {},
    }

    local section = ""
    local handle = fs.open(path, "r")

    while true do
        local line = handle.readLine()
        if not line then
            break
        end

        line = line:match("^%s*(.-)%s*$")

        local newSection = line:match("^%[(.-)%]$")
        if newSection then
            section = newSection
            unit.values[section] = unit.values[section] or {}
        elseif line ~= "" and line:sub(1, 1) ~= "#" then
            local key, value = line:match("^([^=]+)=(.*)$")

            if key then
                unit.values[section] = unit.values[section] or {}
                unit.values[section][key] = value
            end
        end
    end

    handle.close()
    return unit
end

local function description(unit)
    if unit and unit.values.Unit then
        return unit.values.Unit.Description or "ArchCC unit"
    end

    return "ArchCC unit"
end

local function enabled(name)
    return fs.exists(fs.combine(WANTS_DIR, name))
end

local function active(name)
    if name == "multi-user.target" or name == "getty@tty1.service" then
        return true
    end

    return fs.exists(fs.combine(RUN_DIR, name))
end

local function status(name)
    local unit = parseUnit(name)

    if not unit then
        printError("Unit " .. name .. " could not be found.")
        return false
    end

    local isActive = active(name)

    write("● " .. name .. " - " .. description(unit) .. "\n")
    print("     Loaded: loaded (/" .. unit.path .. "; " ..
        (enabled(name) and "enabled" or "disabled") .. ")")
    print("     Active: " ..
        (isActive and "active (running)" or "inactive (dead)"))

    return isActive
end

local function listUnitFiles()
    local found = {}

    for _, directory in ipairs(SYSTEM_DIRS) do
        if fs.exists(directory) then
            for _, name in ipairs(fs.list(directory)) do
                if name:match("%.service$") or name:match("%.target$") then
                    found[name] = true
                end
            end
        end
    end

    local names = {}
    for name in pairs(found) do
        names[#names + 1] = name
    end
    table.sort(names)

    print("UNIT FILE                  STATE")

    for _, name in ipairs(names) do
        print(string.format(
            "%-26s %s",
            name,
            enabled(name) and "enabled" or "disabled"
        ))
    end

    print("")
    print(tostring(#names) .. " unit files listed.")
end

local command = args[1]

if not command then
    print("systemctl [COMMAND] [UNIT]")
    return
end

if command == "status" then
    status(args[2] or "multi-user.target")

elseif command == "is-active" then
    local name = args[2]

    if name and active(name) then
        print("active")
    else
        print("inactive")
    end

elseif command == "is-enabled" then
    local name = args[2]

    if name and enabled(name) then
        print("enabled")
    else
        print("disabled")
    end

elseif command == "enable" then
    local name = args[2]
    local unit = name and parseUnit(name)

    if not unit then
        printError("Unit " .. tostring(name) .. " could not be found.")
        return
    end

    mkdirp(WANTS_DIR)
    writeFile(fs.combine(WANTS_DIR, name), unit.path .. "\n")

    print("Created enablement record /" ..
        fs.combine(WANTS_DIR, name) .. ".")

elseif command == "disable" then
    local name = args[2]
    local path = name and fs.combine(WANTS_DIR, name)

    if path and fs.exists(path) then
        fs.delete(path)
    end

    print("Removed enablement record for " .. tostring(name) .. ".")

elseif command == "start" then
    local name = args[2]
    local unit = name and parseUnit(name)

    if not unit then
        printError("Unit " .. tostring(name) .. " could not be found.")
        return
    end

    if active(name) then
        return
    end

    local service = unit.values.Service or {}
    local commandLine = service.ExecStart

    if not commandLine then
        printError("Unit " .. name .. " has no ExecStart.")
        return
    end

    local words

    if textutils.tokenise then
        words = textutils.tokenise(commandLine)
    else
        words = {}
        for word in commandLine:gmatch("%S+") do
            words[#words + 1] = word
        end
    end

    local program = table.remove(words, 1)

    if shell.openTab then
        local tab = shell.openTab(program, unpackValues(words))
        writeFile(fs.combine(RUN_DIR, name), tostring(tab) .. "\n")
    else
        printError("Background services require multishell support.")
    end

elseif command == "stop" then
    local name = args[2]
    local statePath = name and fs.combine(RUN_DIR, name)

    if statePath and fs.exists(statePath) then
        os.queueEvent("archcc_service_stop", name)
        fs.delete(statePath)
        print("Stop requested for " .. name .. ".")
    end

elseif command == "restart" then
    printError("systemctl: restart is not implemented in ArchCC 0.1")

elseif command == "daemon-reload" then
    print("ArchCC unit configuration reloaded.")

elseif command == "list-unit-files" then
    listUnitFiles()

elseif command == "get-default" then
    print("multi-user.target")

else
    printError("systemctl: unknown command: " .. tostring(command))
end
]=])

