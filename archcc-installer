writeFile("usr/bin/pacman.lua", [=[local args = { ... }

local LOCAL_DB = "var/lib/pacman/local"
local SYNC_DB = "var/lib/pacman/sync/core.db"
local LOG_FILE = "var/log/pacman.log"

local protectedPackages = {
    base = true,
    filesystem = true,
    pacman = true,
    ["archcc-release"] = true,
    ["archcc-shell"] = true,
}

local function mkdirp(path)
    if path == "" then
        return
    end

    local current = ""

    for part in path:gmatch("[^/]+") do
        current = fs.combine(current, part)

        if not fs.exists(current) then
            fs.makeDir(current)
        end
    end
end

local function readFile(path)
    local handle = fs.open(path, "r")
    if not handle then
        return nil
    end

    local contents = handle.readAll()
    handle.close()
    return contents
end

local function writeFile(path, contents)
    mkdirp(fs.getDir(path))

    local handle, reason = fs.open(path, "w")
    if not handle then
        error("could not write " .. path .. ": " .. tostring(reason), 0)
    end

    handle.write(contents)
    handle.close()
end

local function appendLog(message)
    local previous = readFile(LOG_FILE) or ""
    writeFile(LOG_FILE, previous .. "[ALPM] " .. message .. "\n")
end

local function parseDescription(path)
    local contents = readFile(path)
    if not contents then
        return nil
    end

    local result = {}
    local current

    for line in (contents .. "\n"):gmatch("(.-)\n") do
        local section = line:match("^%%(.+)%%$")

        if section then
            current = section
            result[current] = result[current] or {}
        elseif line ~= "" and current then
            result[current][#result[current] + 1] = line
        end
    end

    return result
end

local function sectionValue(data, name, default)
    if data and data[name] and data[name][1] then
        return data[name][1]
    end

    return default
end

local function installedPackages()
    local packages = {}

    if not fs.exists(LOCAL_DB) then
        return packages
    end

    for _, directory in ipairs(fs.list(LOCAL_DB)) do
        local descPath = fs.combine(fs.combine(LOCAL_DB, directory), "desc")
        local desc = parseDescription(descPath)

        if desc then
            local name = sectionValue(desc, "NAME")

            if name then
                packages[name] = {
                    directory = directory,
                    description = desc,
                }
            end
        end
    end

    return packages
end

local function installed(name)
    return installedPackages()[name]
end

local function loadRepository()
    local contents = readFile(SYNC_DB)
    if not contents then
        return {
            name = "core",
            packages = {},
        }
    end

    local repository = textutils.unserialize(contents)

    if type(repository) ~= "table" then
        error("invalid sync database", 0)
    end

    return repository
end

local function packageSize(pkg)
    local size = 0

    for _, contents in pairs(pkg.files or {}) do
        size = size + #contents
    end

    return size
end

local function makeSection(name, values)
    if values == nil then
        return ""
    end

    if type(values) ~= "table" then
        values = { tostring(values) }
    end

    if #values == 0 then
        return ""
    end

    return "%" .. name .. "%\n" ..
        table.concat(values, "\n") .. "\n\n"
end

local function removeOldDatabaseEntry(name)
    local current = installed(name)

    if current then
        fs.delete(fs.combine(LOCAL_DB, current.directory))
    end
end

local function writeInstalledDatabase(pkg, reason)
    removeOldDatabaseEntry(pkg.name)

    local directoryName = pkg.name .. "-" .. pkg.version
    local directory = fs.combine(LOCAL_DB, directoryName)

    mkdirp(directory)

    local fileNames = {}
    for path in pairs(pkg.files or {}) do
        fileNames[#fileNames + 1] = path
    end
    table.sort(fileNames)

    local desc =
        makeSection("NAME", pkg.name) ..
        makeSection("VERSION", pkg.version) ..
        makeSection("BASE", pkg.base or pkg.name) ..
        makeSection("DESC", pkg.description or "") ..
        makeSection("URL", pkg.url or "https://archlinux.org/") ..
        makeSection("ARCH", pkg.arch or "cc-lua") ..
        makeSection("BUILDDATE", tostring(pkg.buildDate or 0)) ..
        makeSection("INSTALLDATE", tostring(os.day())) ..
        makeSection("PACKAGER", pkg.packager or "ArchCC Build System") ..
        makeSection("SIZE", tostring(packageSize(pkg))) ..
        makeSection("REASON", tostring(reason or 0)) ..
        makeSection("VALIDATION", "None") ..
        makeSection("DEPENDS", pkg.depends or {})

    writeFile(fs.combine(directory, "desc"), desc)
    writeFile(
        fs.combine(directory, "files"),
        makeSection("FILES", fileNames)
    )
end

local function normaliseDependency(value)
    return value:match("^([%w%+%-%._]+)")
end

local function installPackage(pkg, reason, repository, visiting)
    visiting = visiting or {}

    if visiting[pkg.name] then
        error("dependency cycle involving " .. pkg.name, 0)
    end

    visiting[pkg.name] = true

    for _, dependencyText in ipairs(pkg.depends or {}) do
        local dependency = normaliseDependency(dependencyText)

        if dependency and not installed(dependency) then
            local dependencyPackage = repository.packages[dependency]

            if not dependencyPackage then
                error(
                    "failed to prepare transaction (could not satisfy dependencies)\n" ..
                    ":: unable to satisfy dependency '" .. dependency ..
                    "' required by " .. pkg.name,
                    0
                )
            end

            print("resolving dependencies...")
            installPackage(dependencyPackage, 1, repository, visiting)
        end
    end

    visiting[pkg.name] = nil

    for path, contents in pairs(pkg.files or {}) do
        writeFile(path, contents)
    end

    writeInstalledDatabase(pkg, reason)
    appendLog("installed " .. pkg.name .. " (" .. pkg.version .. ")")
end

local function removePackage(name)
    local current = installed(name)

    if not current then
        printError("error: target not found: " .. name)
        return false
    end

    if protectedPackages[name] then
        printError("error: refusing to remove protected base package: " .. name)
        return false
    end

    local directory = fs.combine(LOCAL_DB, current.directory)
    local filesData = parseDescription(fs.combine(directory, "files"))

    if filesData and filesData.FILES then
        for _, path in ipairs(filesData.FILES) do
            if fs.exists(path) and not fs.isDir(path) then
                fs.delete(path)
            end
        end
    end

    fs.delete(directory)
    appendLog("removed " .. name)

    return true
end

local function packageInfo(pkg, repositoryName)
    print("Repository      : " .. tostring(repositoryName or "local"))
    print("Name            : " .. pkg.name)
    print("Version         : " .. pkg.version)
    print("Description     : " .. (pkg.description or ""))
    print("Architecture    : " .. (pkg.arch or "cc-lua"))
    print("URL             : " .. (pkg.url or "https://archlinux.org/"))
    print("Licenses        : " .. table.concat(pkg.licenses or { "custom" }, " "))
    print("Depends On      : " ..
        (#(pkg.depends or {}) > 0 and table.concat(pkg.depends, " ") or "None"))
    print("Installed Size  : " .. tostring(packageSize(pkg)) .. " B")
    print("Packager        : " .. (pkg.packager or "ArchCC Build System"))
end

local function installedInfo(name)
    local current = installed(name)

    if not current then
        printError("error: package '" .. name .. "' was not found")
        return
    end

    local data = current.description

    print("Name            : " .. sectionValue(data, "NAME", ""))
    print("Version         : " .. sectionValue(data, "VERSION", ""))
    print("Description     : " .. sectionValue(data, "DESC", ""))
    print("Architecture    : " .. sectionValue(data, "ARCH", ""))
    print("URL             : " .. sectionValue(data, "URL", ""))
    print("Depends On      : " ..
        (data.DEPENDS and table.concat(data.DEPENDS, " ") or "None"))
    print("Install Reason  : " ..
        (sectionValue(data, "REASON", "0") == "0"
            and "Explicitly installed"
            or "Installed as a dependency"))
    print("Validated By    : " .. sectionValue(data, "VALIDATION", "None"))
end

local function optionPresent(letter)
    for _, arg in ipairs(args) do
        if arg:sub(1, 1) == "-" and arg:sub(1, 2) ~= "--" then
            if arg:find(letter, 2, true) then
                return true
            end
        end
    end

    return false
end

local function targets()
    local result = {}

    for _, arg in ipairs(args) do
        if arg:sub(1, 1) ~= "-" then
            result[#result + 1] = arg
        end
    end

    return result
end

if #args == 0 then
    print("usage: pacman <operation> [...]")
    return
end

if args[1] == "-V" or args[1] == "--version" then
    print("")
    print(" .--.                  Pacman v1.0.0-archcc")
    print("/ _.-' .-.  .-.  .-.  Lua-native package manager")
    print("\\  '-. '-'  '-'  '-'  for ArchCC")
    print(" '--'")
    print("")
    return
end

local operation

if optionPresent("Q") then
    operation = "query"
elseif optionPresent("S") then
    operation = "sync"
elseif optionPresent("R") then
    operation = "remove"
elseif optionPresent("U") then
    operation = "upgrade-file"
end

local requestedTargets = targets()

if operation == "query" then
    local packages = installedPackages()

    if optionPresent("i") then
        for _, name in ipairs(requestedTargets) do
            installedInfo(name)
        end

    elseif optionPresent("l") then
        for _, name in ipairs(requestedTargets) do
            local current = packages[name]

            if not current then
                printError("error: package '" .. name .. "' was not found")
            else
                local directory = fs.combine(LOCAL_DB, current.directory)
                local data = parseDescription(fs.combine(directory, "files"))

                for _, path in ipairs((data and data.FILES) or {}) do
                    print(name .. " /" .. path)
                end
            end
        end

    else
        local names = {}
        for name in pairs(packages) do
            names[#names + 1] = name
        end
        table.sort(names)

        for _, name in ipairs(names) do
            print(
                name .. " " ..
                sectionValue(packages[name].description, "VERSION", "")
            )
        end
    end

elseif operation == "sync" then
    local repository = loadRepository()

    if optionPresent("s") then
        local query = requestedTargets[1] or ""

        for name, pkg in pairs(repository.packages) do
            local searchable =
                name:lower() .. " " ..
                (pkg.description or ""):lower()

            if searchable:find(query:lower(), 1, true) then
                print("core/" .. name .. " " .. pkg.version)
                print("    " .. (pkg.description or ""))
            end
        end

    elseif optionPresent("i") then
        for _, name in ipairs(requestedTargets) do
            local pkg = repository.packages[name]

            if not pkg then
                printError("error: package '" .. name .. "' was not found")
            else
                packageInfo(pkg, repository.name)
            end
        end

    elseif optionPresent("y") and #requestedTargets == 0 then
        print(":: Synchronizing package databases...")
        print(" core is up to date")

        if optionPresent("u") then
            print(":: Starting full system upgrade...")
            print(" there is nothing to do")
        end

    else
        local queue = {}
        local totalSize = 0

        for _, name in ipairs(requestedTargets) do
            local pkg = repository.packages[name]

            if not pkg then
                printError("error: target not found: " .. name)
                return
            end

            queue[#queue + 1] = pkg
            totalSize = totalSize + packageSize(pkg)
        end

        if #queue == 0 then
            printError("error: no targets specified")
            return
        end

        print("resolving dependencies...")
        print("looking for conflicting packages...")
        print("")
        print("Packages (" .. #queue .. ")")

        for _, pkg in ipairs(queue) do
            print("  " .. pkg.name .. "-" .. pkg.version)
        end

        print("")
        print("Total Installed Size: " .. totalSize .. " B")
        print("")
        write(":: Proceed with installation? [Y/n] ")

        local answer = read()
        answer = (answer or ""):lower()

        if answer ~= "" and answer ~= "y" and answer ~= "yes" then
            print("installation aborted")
            return
        end

        print("")
        print(":: Processing package changes...")

        for _, pkg in ipairs(queue) do
            print("installing " .. pkg.name .. "...")
            installPackage(pkg, 0, repository)
        end
    end

elseif operation == "remove" then
    if #requestedTargets == 0 then
        printError("error: no targets specified")
        return
    end

    print("checking dependencies...")
    print("")
    print("Packages (" .. #requestedTargets .. ") " ..
        table.concat(requestedTargets, " "))
    print("")
    write(":: Do you want to remove these packages? [Y/n] ")

    local answer = (read() or ""):lower()

    if answer ~= "" and answer ~= "y" and answer ~= "yes" then
        print("removal aborted")
        return
    end

    for _, name in ipairs(requestedTargets) do
        if removePackage(name) then
            print("removing " .. name .. "...")
        end
    end

elseif operation == "upgrade-file" then
    for _, path in ipairs(requestedTargets) do
        local contents = readFile(path)

        if not contents then
            printError("error: '" .. path .. "': could not open package")
            return
        end

        local pkg = textutils.unserialize(contents)

        if type(pkg) ~= "table" or not pkg.name or not pkg.version then
            printError("error: '" .. path .. "': invalid package format")
            return
        end

        installPackage(pkg, 0, loadRepository())
    end

else
    printError("error: only -Q, -S, -R and -U are implemented")
end
]=])

