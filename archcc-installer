local function section(name, values)
    if type(values) ~= "table" then
        values = { tostring(values) }
    end

    if #values == 0 then
        return ""
    end

    return "%" .. name .. "%\n" ..
        table.concat(values, "\n") .. "\n\n"
end

local function registerInstalled(pkg)
    local directory = fs.combine(
        "var/lib/pacman/local",
        pkg.name .. "-" .. pkg.version
    )

    mkdirp(directory)

    local files = pkg.files or {}
    table.sort(files)

    local desc =
        section("NAME", pkg.name) ..
        section("VERSION", pkg.version) ..
        section("BASE", pkg.name) ..
        section("DESC", pkg.description) ..
        section("URL", pkg.url or "https://archlinux.org/") ..
        section("ARCH", "cc-lua") ..
        section("BUILDDATE", tostring(timestamp())) ..
        section("INSTALLDATE", tostring(timestamp())) ..
        section("PACKAGER", "ArchCC Build System") ..
        section("SIZE", "0") ..
        section("REASON", "0") ..
        section("VALIDATION", "None") ..
        section("DEPENDS", pkg.depends or {})

    writeFile(fs.combine(directory, "desc"), desc)
    writeFile(fs.combine(directory, "files"), section("FILES", files))
end

