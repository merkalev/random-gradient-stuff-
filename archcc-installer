writeFile("usr/bin/archcc-shell.lua", [=[local history = {}

local function readAll(path)
    local handle = fs.open(path, "r")
    if not handle then
        return nil
    end

    local contents = handle.readAll()
    handle.close()
    return contents
end

local function hostname()
    local value = readAll("etc/hostname") or "archcc"
    return value:gsub("%s+$", "")
end

local function username()
    local value = readAll("run/archcc/user") or "root"
    return value:gsub("%s+$", "")
end

local function displayPath()
    local current = shell.dir()

    if current == "" then
        return "/"
    end

    current = "/" .. current

    local home = username() == "root" and "/root" or "/home/" .. username()

    if current == home then
        return "~"
    elseif current:sub(1, #home + 1) == home .. "/" then
        return "~" .. current:sub(#home + 1)
    end

    return current
end

local function configureAliases()
    local aliases = {
        ls = "list",
        dir = "list",
        cp = "copy",
        mv = "move",
        rm = "delete",
        cat = "type",
        nano = "edit",
    }

    for alias, program in pairs(aliases) do
        if shell.setAlias then
            shell.setAlias(alias, program)
        end
    end
end

local function drawPrompt()
    local colour = term.isColor and term.isColor()

    if colour then
        term.setTextColor(colors.green)
    end

    write("[" .. username() .. "@" .. hostname() .. " ")

    if colour then
        term.setTextColor(colors.blue)
    end

    write(displayPath())

    if colour then
        term.setTextColor(colors.green)
    end

    write("]")

    if colour then
        term.setTextColor(colors.white)
    end

    if username() == "root" then
        write("# ")
    else
        write("$ ")
    end
end

shell.setPath(
    "usr/local/bin:usr/bin:bin:" ..
    "/rom/programs:/rom/programs/http:/rom/programs/fun"
)

configureAliases()

if username() == "root" then
    shell.setDir("root")
else
    local home = "home/" .. username()
    if not fs.exists(home) then
        fs.makeDir(home)
    end
    shell.setDir(home)
end

local motd = readAll("etc/motd")
if motd then
    print(motd)
end

while true do
    drawPrompt()

    local line

    if shell.complete then
        line = read(nil, history, shell.complete)
    else
        line = read(nil, history)
    end

    line = line or ""
    line = line:match("^%s*(.-)%s*$")

    if line ~= "" then
        history[#history + 1] = line

        if #history > 100 then
            table.remove(history, 1)
        end

        if line == "exit" or line == "logout" then
            return
        elseif line == "pwd" then
            print("/" .. shell.dir())
        elseif line:match("^export%s+") then
            printError("archcc-shell: persistent environment variables are not implemented yet")
        else
            shell.run(line)
        end
    end
end
]=])

